@model Dictionary<int, string>

<table>
    <thead>
        <th>ID</th>
        <th>Valor</th>
    </thead>
    <tbody>
        @foreach (var data in Model)
        {
            <tr>
                <td>@data.Key</td>
                <td>data.Value</td>
            </tr>
        }
    </tbody>
</table>